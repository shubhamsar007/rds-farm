26,23,0.3) 0%, rgba(28,26,23,0.15) 40%, rgba(28,26,23,0.7) 100%)\"></div><div style=\"position:relative;z-index:10;text-align:center;padding:0 1.5rem;max-width:900px\"><div style=\"opacity:0;transform:translateY(30px)\"><p style=\"font-family:var(--font-inter), Inter, system-ui, sans-serif;font-size:0.6875rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:#B8976A;margin-bottom:1.5rem\">  RD Developers · Ahmedabad</p><h1 style=\"font-family:var(--font-playfair), &#x27;Playfair Display&#x27;, Georgia, serif;font-style:italic;font-weight:400;font-size:clamp(2.5rem, 6vw, 5rem);line-height:1.15;color:#F5EFE4;margin-bottom:1.5rem;letter-spacing:-0.01em;white-space:pre-line\">  Building Homes That Stand the Test of Time</h1><p style=\"font-family:var(--font-inter), Inter, system-ui, sans-serif;font-size:clamp(0.9375rem, 1.5vw, 1.125rem);font-weight:300;color:rgba(245,239,228,0.85);letter-spacing:0.02em;line-height:1.6\">Trusted construction and real estate development across Ahmedabad, delivering quality homes and commercial spaces for over 15 years.</p></div></div><div style=\"position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);z-index:10;opacity:0\"><div style=\"color:rgba(245,239,228,0.7)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></div></section><section style=\"background-color:#F5EFE4;padding:7rem 1.5rem\"><div style=\"max-width:860px;margin:0 auto;text-align:center\"><div style=\"opacity:0;transform:translateY(20px)\"><p style=\"font-family:var(--font-inter), Inter, system-ui, sans-serif;font-size:0.6875rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:#B8976A;margin-bottom:1.25rem\">About Us</p><h2 style=\"font-family:var(--font-playfair), &#x27;Playfair Display&#x27;, Georgia, serif;font-style:italic;font-weight:400;font-size:clamp(1.75rem, 3.5vw, 3rem);line-height:1.25;color:#1C1A17;margin-bottom:2rem;letter-spacing:-0.01em\">About RD Developers</h2><div style=\"width:48px;height:1px;background-color:#B8976A;margin:0 auto 2rem\"></div><p style=\"font-family:var(--font-inter), Inter, system-ui, sans-serif;font-size:1rem;line-height:1.85;color:#7A6F62;margin-bottom:0\">RD Developers has been a name synonymous with trust and quality in Ahmedabad&#x27;s real estate landscape. With a focus on thoughtful design, durable construction, and timely delivery, we&#x27;ve built residential and commercial spaces that families and businesses are proud to call home. Our team blends traditional craftsmanship with modern construction practices to create properties that stand strong for generations.</p></div><div style=\"display:grid;grid-template-columns:repeat(3, 1fr);gap:2rem;margin-top:4rem;padding-top:3rem;border-top:1px solid #D9CDBF;opacity:0;transform:translateY(20px)\"><div style=\"text-align:center\"><div style=\"font-family:var(--font-playfair), &#x27;Playfair Display&#x27;, Georgia, serif;font-weight:600;font-size:clamp(1.75rem, 3.5vw, 2.5rem);color:#2D5F4F;margin-bottom:0.25rem\">50+</div><div style=\"font-family:var(--font-inter), Inter, system-ui, sans-serif;font-size:0.8125rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#7A6F62\">Rooms</div></div><div style=\"text-align:center\"><div style=\"font-family:var(--font-playfair), &#x27;Playfair Display&#x27;, Georgia, serif;font-weight:600;font-size:clamp(1.75rem, 3.5vw, 2.5rem);color:#2D5F4F;margin-bottom:0.25rem\">3</div><div style=\"font-family:var(--font-inter), Inter, system-ui, sans-serif;font-size:0.8125rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#7A6F62\">Properties</div></div><div style=\"text-align:center\"><div style=\"font-family:var(--font-playfair), &#x27;Playfair Display&#x27;, Georgia, serif;font-weight:600;font-size:cla